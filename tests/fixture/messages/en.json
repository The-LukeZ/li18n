{
  "$schema": "../../../messages.schema.json",
  "greeting": "Hello {name}!",
  "farewell": "Goodbye",
  "unread": "You have {count:num} unread messages",
  "nav": {
    "home": "Home",
    "about": "About"
  },
  "role": [{ "var": { "bool": "isAdmin" }, "cases": { "true": "Admin", "false": "User" } }],
  "items": [
    {
      "var": { "num": "count" },
      "cases": { "1": "One item", ">= 10": "Many items", "else": "{count} items" }
    }
  ],
  "lang": [
    {
      "var": "locale",
      "cases": { "en": "English", "de": "German", "else": "Other" }
    }
  ],
  "delete": "Delete {item}"
}
