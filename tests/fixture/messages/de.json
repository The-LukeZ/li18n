{
  "$schema": "../../../messages.schema.json",
  "greeting": "Hallo {name}!",
  "farewell": "Auf Wiedersehen",
  "unread": "Du hast {count:num} ungelesene Nachrichten",
  "nav": {
    "home": "Startseite",
    "about": "Über uns"
  },
  "role": [{ "var": { "bool": "isAdmin" }, "cases": { "true": "Admin", "false": "Benutzer" } }],
  "items": [
    {
      "var": { "num": "count" },
      "cases": { "1": "Ein Artikel", ">= 10": "Viele Artikel", "else": "{count} Artikel" }
    }
  ],
  "lang": [
    {
      "var": "locale",
      "cases": { "en": "Englisch", "de": "Deutsch", "else": "Andere" }
    }
  ]
}
